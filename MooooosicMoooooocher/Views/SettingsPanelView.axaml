<UserControl x:Class="MooooosicMoooooocher.Views.SettingsPanelView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:MooooosicMoooooocher.Models">
  <StackPanel Spacing="12">
    <TextBlock Text="Settings"
               FontSize="18"
               FontWeight="SemiBold"
               Foreground="{StaticResource TextBrush}" />

    <StackPanel Spacing="6">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Output Folder" Foreground="{StaticResource TextBrush}" />
        <Button Grid.Column="1"
                Click="OnBrowseClick"
                Background="{StaticResource BackgroundBrush}"
                ToolTip.Tip="Choose folder">
          <PathIcon Width="12" Height="12"
                    Foreground="{StaticResource TextBrush}"
                    Data="M1,3 H7 L9,1 H15 V13 H1 Z M1,5 H15" />
        </Button>
      </Grid>
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding OutputFolder}"
                 Watermark="C:\Music"
                 Background="{StaticResource BackgroundBrush}"
                 IsReadOnly="True" />
        <Border Grid.Column="1" Width="8" />
      </Grid>
    </StackPanel>

    <StackPanel Spacing="6">
      <TextBlock Text="Auth Token" Foreground="{StaticResource TextBrush}" />
      <TextBox Text="{Binding AuthToken}"
               Watermark="Required for WAV"
               Background="{StaticResource SurfaceBrush}" />
    </StackPanel>

    <Grid ColumnDefinitions="*,*">
      <StackPanel Grid.Column="0" Spacing="6">
        <TextBlock Text="File Format" Foreground="{StaticResource TextBrush}" />
        <ComboBox ItemsSource="{Binding Formats}"
                  SelectedItem="{Binding PreferredFormat}"
                  Background="{StaticResource SurfaceBrush}" />
      </StackPanel>

      <StackPanel Grid.Column="1" Spacing="6" Margin="12,0,0,0">
        <TextBlock Text="View Zoom" Foreground="{StaticResource TextBrush}" />
        <ComboBox ItemsSource="{Binding DataContext.ZoomPresets, RelativeSource={RelativeSource AncestorType=Window}}"
                  SelectedItem="{Binding DataContext.SelectedZoomPreset, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                  Background="{StaticResource SurfaceBrush}" />
      </StackPanel>
    </Grid>
  </StackPanel>
</UserControl>
