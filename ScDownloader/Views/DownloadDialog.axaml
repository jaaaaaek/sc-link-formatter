<Window x:Class="ScDownloader.Views.DownloadDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:anim="https://github.com/whistyun/AnimatedImage.Avalonia"
        Width="460"
        Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource SurfaceBrush}"
        Title="Downloading dependency">

  <Border Padding="16">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

      <!-- Animation area: Classic Windows download animation -->
      <Image Grid.Row="0" Height="60" Margin="0,0,0,12"
             anim:ImageBehavior.AnimatedSource="avares://ScDownloader/Assets/download-animation.gif" />

      <!-- Saving label -->
      <TextBlock x:Name="StatusText"
                 Grid.Row="1"
                 Text=""
                 Foreground="{StaticResource TextBrush}"
                 FontSize="12"
                 Margin="0,0,0,8" />

      <!-- Chunky block progress bar -->
      <Border Grid.Row="2" Background="#1A1A1A" BorderBrush="#555555" BorderThickness="1"
              Height="22" Margin="0,0,0,10" Padding="2">
        <Canvas x:Name="ProgressCanvas" ClipToBounds="True" />
      </Border>

      <!-- Info grid: Estimated time / Download to / Transfer rate -->
      <Grid Grid.Row="3" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,4">
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Estimated time left:"
                   Foreground="#AAAAAA" FontSize="12" Margin="0,0,8,3" />
        <TextBlock x:Name="EtaText" Grid.Row="0" Grid.Column="1"
                   Text=""
                   Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,3" />

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Download to:"
                   Foreground="#AAAAAA" FontSize="12" Margin="0,0,8,3" />
        <TextBlock x:Name="DestinationText" Grid.Row="1" Grid.Column="1"
                   Text="" TextTrimming="CharacterEllipsis"
                   Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,3" />

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Transfer rate:"
                   Foreground="#AAAAAA" FontSize="12" Margin="0,0,8,0" />
        <TextBlock x:Name="SpeedText" Grid.Row="2" Grid.Column="1"
                   Text=""
                   Foreground="{StaticResource TextBrush}" FontSize="12" />
      </Grid>

      <!-- Error message -->
      <TextBlock x:Name="ErrorText"
                 Grid.Row="5"
                 Text=""
                 Foreground="{StaticResource ErrorBrush}"
                 TextWrapping="Wrap"
                 IsVisible="False" />
    </Grid>
  </Border>
</Window>
