<UserControl x:Class="LinkFormatter.Views.ProgressConsoleView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
    <StackPanel Spacing="8">
      <TextBlock Text="Progress Console"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextBrush}" />
      <ScrollViewer Height="140"
                    Background="{StaticResource BackgroundBrush}"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Visible">
        <TextBox Text="{Binding Content}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="12"
                 Foreground="{StaticResource TextBrush}"
                 Background="{StaticResource BackgroundBrush}" />
      </ScrollViewer>
    </StackPanel>
  </Border>
</UserControl>
