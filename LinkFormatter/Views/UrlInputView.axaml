<UserControl x:Class="LinkFormatter.Views.UrlInputView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
    <StackPanel Spacing="8">
      <TextBlock Text="Add SoundCloud URLs"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextBrush}" />

      <ScrollViewer Height="96"
                    Background="{StaticResource BackgroundBrush}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    AllowAutoHide="False">
        <TextBox Text="{Binding UrlText}"
                 Watermark="https://soundcloud.com/artist/track"
                 Background="{StaticResource BackgroundBrush}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap" />
      </ScrollViewer>

      <WrapPanel Orientation="Horizontal">
        <Button Content="Add"
                Command="{Binding AddUrlCommand}"
                Background="{StaticResource ClaudeOrangeBrush}"
                Foreground="White"
                Margin="0,0,10,0" />
        <TextBlock Text="{Binding ValidationMessage}"
                   Foreground="{StaticResource ErrorBrush}"
                   VerticalAlignment="Center"
                   FontSize="13"
                   IsVisible="{Binding HasError}"
                   Margin="0,0,8,0" />
        <Button IsVisible="{Binding HasMultipleErrors}"
                Command="{Binding ToggleErrorDetailsCommand}"
                FontSize="11"
                Padding="4,1"
                VerticalAlignment="Center"
                Background="Transparent"
                Foreground="{StaticResource ClaudeOrangeBrush}">
          <Panel>
            <TextBlock Text="Show details" IsVisible="{Binding !ShowErrorDetails}" />
            <TextBlock Text="Hide details" IsVisible="{Binding ShowErrorDetails}" />
          </Panel>
        </Button>
      </WrapPanel>

      <ScrollViewer MaxHeight="500"
                    IsVisible="{Binding ShowErrorDetails}"
                    Background="{StaticResource BackgroundBrush}"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    AllowAutoHide="False">
        <ItemsControl ItemsSource="{Binding Details}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <TextBlock Text="{Binding Message}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="4,1"
                           IsVisible="{Binding IsError}" />
                <TextBlock Text="{Binding Message}"
                           Foreground="{StaticResource SuccessBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="4,1"
                           IsVisible="{Binding !IsError}" />
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </StackPanel>
  </Border>
</UserControl>
