<UserControl x:Class="LinkFormatter.Views.FilesListView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12" VerticalAlignment="Stretch">
    <Grid RowDefinitions="Auto,*">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Text="Downloaded Files"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" />
        <Button Grid.Column="1"
                Margin="6,0,0,0"
                ToolTip.Tip="Refresh"
                FontSize="14"
                Padding="6,2"
                MinHeight="24"
                Command="{Binding RefreshCommand}"
                Background="{StaticResource BackgroundBrush}">
          <TextBlock Text="↻" />
        </Button>
        <Button Grid.Column="2"
                Margin="6,0,0,0"
                ToolTip.Tip="Clear"
                FontSize="14"
                Padding="6,2"
                MinHeight="24"
                Click="OnClearClicked"
                Background="{StaticResource BackgroundBrush}">
          <TextBlock Text="🗑" />
        </Button>
      </Grid>

      <Border Grid.Row="1"
              Margin="0,8,0,0"
              Background="{StaticResource BackgroundBrush}"
              BorderBrush="{StaticResource TextBrush}"
              BorderThickness="0.5"
              CornerRadius="4"
              Padding="6"
              VerticalAlignment="Stretch">
        <ListBox ItemsSource="{Binding Files}"
                 Background="Transparent"
                 BorderThickness="0"
                 MinHeight="140"
                 VerticalAlignment="Stretch">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding DisplayName}"
                         Foreground="{StaticResource TextBrush}"
                         FontSize="12"
                         Background="Transparent"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Padding="0"
                         MinWidth="120" />
                <Button Content="Open"
                        Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>
  </Border>
</UserControl>
