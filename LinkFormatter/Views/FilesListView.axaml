<UserControl x:Class="LinkFormatter.Views.FilesListView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12" VerticalAlignment="Stretch">
    <Grid RowDefinitions="Auto,*">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <Panel>
          <TextBlock Text="Downloaded Files"
                     IsVisible="{Binding !ShowingUrls}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}" />
          <TextBlock Text="Downloaded URLs"
                     IsVisible="{Binding ShowingUrls}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextBrush}" />
        </Panel>
        <Button Grid.Column="1"
                Margin="6,0,0,0"
                ToolTip.Tip="Show downloaded URLs"
                FontSize="14"
                Padding="6,2"
                MinHeight="24"
                Command="{Binding ToggleUrlsCommand}"
                Background="{StaticResource BackgroundBrush}">
          <Panel>
            <TextBlock Text="🔗" IsVisible="{Binding !ShowingUrls}" />
            <TextBlock Text="📁" IsVisible="{Binding ShowingUrls}" />
          </Panel>
        </Button>
        <Button Grid.Column="2"
                Margin="6,0,0,0"
                ToolTip.Tip="Clear"
                FontSize="14"
                Padding="6,2"
                MinHeight="24"
                Click="OnClearClicked"
                Background="{StaticResource BackgroundBrush}">
          <TextBlock Text="🗑" />
        </Button>
      </Grid>

      <Border Grid.Row="1"
              Margin="0,8,0,0"
              Background="{StaticResource BackgroundBrush}"
              BorderBrush="{StaticResource TextBrush}"
              BorderThickness="0.5"
              CornerRadius="4"
              Padding="6"
              VerticalAlignment="Stretch">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Hidden">
          <TextBox Text="{Binding FilesText}"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="12"
                   FontFamily="Consolas"
                   Background="Transparent"
                   BorderThickness="0"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="NoWrap"
                   Padding="0" />
        </ScrollViewer>
      </Border>
    </Grid>
  </Border>
</UserControl>
