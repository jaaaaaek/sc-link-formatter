<Window x:Class="LinkFormatter.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LinkFormatter.Views"
        Width="1200"
        Height="800"
        Background="{StaticResource BackgroundBrush}"
        FontSize="{Binding ZoomedFontSize}"
        Title="SoundCloud Downloader">
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+0" Command="{Binding ResetZoomCommand}" />
  </Window.KeyBindings>

  <Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" Padding="16">
        <Grid RowDefinitions="Auto,*">
          <Border Background="{StaticResource SurfaceBrush}"
                  CornerRadius="8"
                  Padding="12">
            <views:SettingsPanelView DataContext="{Binding SettingsPanel}" />
          </Border>
          <views:FilesListView Grid.Row="1"
                               Margin="0,12,0,0"
                               VerticalAlignment="Stretch"
                               DataContext="{Binding FilesList}" />
        </Grid>
      </Border>

      <Grid Grid.Column="1" Margin="16" RowDefinitions="Auto,*,Auto">
        <views:UrlInputView Grid.Row="0" Margin="0,0,0,12" DataContext="{Binding UrlInput}" />
        <views:DownloadQueueView Grid.Row="1" Margin="0,0,0,12" DataContext="{Binding DownloadQueue}" />
        <views:ProgressConsoleView Grid.Row="2" DataContext="{Binding ProgressConsole}" />
      </Grid>

    <Border Background="#AA000000"
            IsVisible="{Binding IsWelcomeVisible}">
      <Grid HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <views:WelcomeView DataContext="{Binding Welcome}" />
      </Grid>
    </Border>
  </Grid>
</Window>
