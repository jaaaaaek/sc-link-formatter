<UserControl x:Class="LinkFormatter.Views.DownloadQueueView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
    <Grid RowDefinitions="Auto,*">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Download Queue"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
          <Button Content="Start"
                  Command="{Binding DataContext.StartDownloadsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  Background="{StaticResource ClaudeOrangeBrush}"
                  Foreground="White" />
          <Button Content="Stop All"
                  Command="{Binding DataContext.StopAllCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  Background="{StaticResource BackgroundBrush}" />
          <Button Content="Clear Done"
                  Command="{Binding ClearCompletedCommand}"
                  Background="{StaticResource BackgroundBrush}" />
        </StackPanel>
      </Grid>

      <ListBox Grid.Row="1"
               Margin="0,8,0,0"
               ItemsSource="{Binding Items}"
               Background="{StaticResource BackgroundBrush}"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               VerticalAlignment="Stretch">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="0" BorderThickness="0,0,0,1" BorderBrush="#333333">
              <Grid ClipToBounds="True">
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{Binding Progress}"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch"
                              Background="{StaticResource ClaudeOrangeBrush}"
                              Foreground="#2F6F3E"
                              IsHitTestVisible="False" />
                <Border Padding="6" Background="Transparent">
                  <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="*">
                      <TextBlock Text="{Binding DisplayName}"
                                 Foreground="{StaticResource TextBrush}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0" />
                    </Grid>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}" FontSize="12" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </Border>
</UserControl>
