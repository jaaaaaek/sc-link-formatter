<UserControl x:Class="LinkFormatter.Views.DownloadQueueView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
    <Grid RowDefinitions="Auto,*">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Download Queue"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
          <Button Content="Start"
                  Command="{Binding DataContext.StartDownloadsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  Background="{StaticResource ClaudeOrangeBrush}"
                  Foreground="White" />
          <Button Content="Stop"
                  Command="{Binding DataContext.StopAllCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  Background="{StaticResource BackgroundBrush}" />
          <Button Content="Clear Done"
                  Command="{Binding ClearCompletedCommand}"
                  Background="{StaticResource BackgroundBrush}" />
          <Button Content="Clear All"
                  Command="{Binding DataContext.ClearAllQueueCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                  Background="{StaticResource BackgroundBrush}" />
        </StackPanel>
      </Grid>

      <ListBox Grid.Row="1"
               Margin="0,8,0,0"
               ItemsSource="{Binding Items}"
               Background="{StaticResource BackgroundBrush}"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               VerticalAlignment="Top">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="Height" Value="24" />
          </Style>
          <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#44FFFFFF" />
          </Style>
          <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#44FFFFFF" />
          </Style>
        </ListBox.Styles>
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="8" />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="0" BorderThickness="0" CornerRadius="3" Margin="0" ClipToBounds="True">
              <Grid ClipToBounds="True">
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{Binding Progress}"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch"
                             Background="{StaticResource ClaudeOrangeBrush}"
                             Foreground="#2F6F3E"
                             CornerRadius="6"
                             IsHitTestVisible="False" />
                <Border Padding="2,0" Background="Transparent" VerticalAlignment="Center">
                  <StackPanel Spacing="2">
                    <Grid ColumnDefinitions="*">
                      <TextBlock Text="{Binding DisplayName}"
                                 Foreground="{StaticResource TextBrush}"
                                 TextTrimming="CharacterEllipsis"
                                 FontSize="12"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Stretch"
                                 TextAlignment="Center"
                                 Margin="0" />
                    </Grid>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="11"
                               IsVisible="{Binding HasErrorMessage}" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </Border>
</UserControl>
