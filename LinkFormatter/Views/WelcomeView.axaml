<UserControl x:Class="LinkFormatter.Views.WelcomeView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Width="520">
    <StackPanel Spacing="12">
      <TextBlock Text="HELLOOOOOOOOOOOOOOOOOO DAMIAAAAN"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="{StaticResource TextBrush}" />

      <TextBlock Text="Let's get you setup"
                 Foreground="{StaticResource TextBrush}"
                 TextWrapping="Wrap" />

      <StackPanel Spacing="6">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Output Folder (required)" Foreground="{StaticResource TextBrush}" />
          <Button Grid.Column="1"
                  Click="OnBrowseClick"
                  Background="{StaticResource BackgroundBrush}">
            <TextBlock Text="Browse"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
          </Button>
        </Grid>
        <TextBox Text="{Binding OutputFolder}"
                 IsReadOnly="True"
                 Watermark="Choose output folder"
                 Background="{StaticResource BackgroundBrush}" />
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="SoundCloud Token (optional)" Foreground="{StaticResource TextBrush}" />
        <TextBox Text="{Binding SoundCloudToken}"
                 Watermark="Only required for WAV"
                 Background="{StaticResource BackgroundBrush}" />
      </StackPanel>

      <CheckBox Content="I only want MP3 downloads"
                IsChecked="{Binding Mp3Only}"
                Foreground="{StaticResource TextBrush}" />

      <StackPanel Spacing="6" IsVisible="{Binding IsFfmpegRequired}">
        <TextBlock Text="FFmpeg is required for audio extraction. Downloading if missing."
                   Foreground="{StaticResource TextBrush}"
                   TextWrapping="Wrap" />
        <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Height="8" />
        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextBrush}" />
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource ErrorBrush}"
                   IsVisible="{Binding HasError}" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Continue"
                Command="{Binding ContinueCommand}"
                Background="{StaticResource ClaudeOrangeBrush}"
                Foreground="White" />
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
