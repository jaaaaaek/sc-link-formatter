<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="ClaudeOrange">#D97757</Color>
  <Color x:Key="BackgroundColor">#1E1E1E</Color>
  <Color x:Key="SurfaceColor">#2D2D2D</Color>
  <Color x:Key="TextColor">#FFFFFF</Color>
  <Color x:Key="SuccessColor">#4CAF50</Color>
  <Color x:Key="ErrorColor">#F44336</Color>

  <SolidColorBrush x:Key="ClaudeOrangeBrush" Color="{StaticResource ClaudeOrange}" />
  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
  <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

  <Color x:Key="SystemAccentColor">#D97757</Color>
  <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{StaticResource SystemAccentColor}" />

</ResourceDictionary>
